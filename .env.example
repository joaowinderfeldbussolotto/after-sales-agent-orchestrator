# Copy this file to .env and fill in your values
# cp .env.example .env

# Required: Groq API key — get one free at https://console.groq.com
GROQ_API_KEY=gsk_...

# Optional: PydanticAI Logfire observability token
LOGFIRE_TOKEN=

# Optional: Langfuse observability (coordinator, logistics, financial)
# Get your keys at https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Optional: Model overrides (defaults shown)
COORDINATOR_MODEL=openai/gpt-oss-120b
LOGISTICS_MODEL=groq:meta-llama/llama-4-scout-17b-16e-instruct
FINANCIAL_MODEL=openai/gpt-oss-20b

# Optional: Timeout tuning (seconds, defaults shown)
A2A_TIMEOUT=60           # JSON-RPC A2A calls (PydanticAI)
A2A_AGNO_TIMEOUT=120     # REST A2A calls (Agno) — synchronous, can be slow
A2A_POLL_TIMEOUT=55      # Max wait during task polling
MCP_HTTP_TIMEOUT=10      # orders-mcp → mock-api HTTP calls
REGISTRY_TIMEOUT=5       # Agent card discovery at startup
